# Frontend environment variables (prefix with VITE_ to expose to browser)
# DO NOT put API keys here — keys go in backend/.env

# Optional internal key if you enable auth middleware
VITE_INTERNAL_API_KEY=

# Client account IDs (optional — can be set via Settings UI instead)
VITE_UPSJB_META_ID=act_
VITE_UPSJB_GOOGLE_ID=
VITE_DECO_META_ID=act_
VITE_DECO_GOOGLE_ID=
VITE_ESPAC_META_ID=act_
VITE_ESPAC_GOOGLE_ID=
VITE_LIBRA_META_ID=act_
VITE_LIBRA_GOOGLE_ID=
