# ─── SERVER ──────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173
INTERNAL_API_KEY=your-internal-api-key-here

# ─── META ADS ────────────────────────────────────────
# Get from: https://developers.facebook.com/tools/explorer/
META_ACCESS_TOKEN=your_meta_long_lived_token_here

# ─── GOOGLE ADS ──────────────────────────────────────
# Developer token from: https://developers.google.com/google-ads/api/docs/get-started/dev-token
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here
# OAuth2 access token (refresh with google-auth-library)
GOOGLE_ADS_ACCESS_TOKEN=your_oauth2_access_token_here
# Manager account ID (without dashes)
GOOGLE_ADS_MANAGER_ID=1234567890

# ─── ANTHROPIC ───────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── OPTIONAL: CLIENT MAP ────────────────────────────
# Map client slugs to account IDs (used by frontend)
# Format: JSON string
CLIENT_ACCOUNTS={"upsjb":{"metaAccountId":"act_000000000","googleCustomerId":"1234567890"},"deco":{"metaAccountId":"act_111111111","googleCustomerId":"9876543210"}}
